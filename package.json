    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.42.2",
    "next": "^16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.20.1",
    "@vercel/node": "^5.8.26",
    "autoprefixer": "^10.5.4",
